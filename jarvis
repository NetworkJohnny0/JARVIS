#!/bin/bash
#
# JARVIS AI Assistant - Main Shell Interface
# Usage: ./jarvis [command]
#

JARVIS_DIR="/opt/jarvis"
OLLAMA_HOST="localhost:11434"
MODEL_NAME="jarvis"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_banner() {
    echo -e "${BLUE}"
    echo "  _______                  _             _    "
    echo " |__   __|                (_)           | |   "
    echo "    | | ___ _ __ _ _ __  _| |_ _   _  __| |  "
    echo "    | |/ _ \\ '__| | '_ \\| __| | | | |/ _\` |  "
    echo "    | |  __/ |  | | | | | |_| |_| | | (_| |  "
    echo "    |_|\\___|_|  |_|_| |_|\\__|\\__, |_| |\\__,_|  "
    echo "                              __/ |          "
    echo "                             |___/           "
    echo -e "${NC}"
    echo -e "${GREEN}JARVIS AI Assistant v1.0${NC} - Your persistent system companion"
    echo ""
}

check_ollama() {
    if curl -s http://$OLLAMA_HOST/api/tags > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

start_ollama() {
    echo -e "${YELLOW}Starting Ollama service...${NC}"
    if command -v ollama &> /dev/null; then
        ollama serve &
        sleep 3
    else
        echo -e "${RED}Ollama not installed. Install with: curl -fsSL https://ollama.ai/install.sh | sh${NC}"
        return 1
    fi
}

load_model() {
    echo -e "${YELLOW}Loading $MODEL_NAME model...${NC}"
    if ollama list | grep -q "$MODEL_NAME"; then
        echo "Model already exists"
    else
        MODELFILE="/opt/jarvis/config/Modelfile"
        if [ -f "$MODELFILE" ]; then
            ollama create $MODEL_NAME -f $MODELFILE 2>/dev/null || echo "Using default model"
        fi
    fi
}

chat() {
    if ! check_ollama; then
        start_ollama
    fi
    
    echo -e "${GREEN}JARVIS is ready. Type 'exit' to quit.${NC}"
    echo ""
    
    while true; do
        echo -ne "${GREEN}You:${NC} "
        read -r query
        
        if [ "$query" = "exit" ] || [ "$query" = "quit" ]; then
            echo -e "${BLUE}JARVIS: Good day, Sir. Shall we continue this conversation later?${NC}"
            break
        fi
        
        if [ -z "$query" ]; then
            continue
        fi
        
        response=$(curl -s http://$OLLAMA_HOST/api/generate -d "{
            \"model\": \"$MODEL_NAME\",
            \"prompt\": \"$query\",
            \"stream\": false
        }" | jq -r '.response' 2>/dev/null)
        
        if [ -n "$response" ]; then
            echo -e "${BLUE}JARVIS:${NC} $response"
        else
            echo -e "${RED}Error getting response. Is Ollama running?${NC}"
        fi
        echo ""
    done
}

status() {
    echo "=== JARVIS System Status ==="
    echo ""
    echo "Ollama: $(check_ollama && echo 'Running' || echo 'Stopped')"
    echo "Model: $MODEL_NAME"
    echo ""
    python3 $JARVIS_DIR/bin/jarvis-agent.py
}

monitor() {
    echo "Starting JARVIS monitoring (Ctrl+C to stop)..."
    python3 $JARVIS_DIR/bin/jarvis-agent.py --daemon
}

case "$1" in
    chat)
        chat
        ;;
    status)
        status
        ;;
    monitor)
        monitor
        ;;
    start)
        start_ollama
        load_model
        chat
        ;;
    *)
        print_banner
        echo "Usage: $0 {chat|status|monitor|start}"
        echo ""
        echo "  chat    - Start interactive chat with JARVIS"
        echo "  status  - Check system health"
        echo "  monitor - Run continuous monitoring agent"
        echo "  start   - Start Ollama and chat"
        echo ""
        ;;
esac
